{
  "name": "tamagui",
  "version": "2.0.0-rc.36",
  "gitHead": "a49cc7ea6b93ba384e77a4880ae48ac4a5635c14",
  "description": "Style and UI for React (web and native) meet an optimizing compiler",
  "repository": {
    "type": "git",
    "url": "https://github.com/tamagui/tamagui.git",
    "directory": "code/ui/tamagui"
  },
  "source": "src/index.ts",
  "type": "module",
  "sideEffects": [
    "setup.js"
  ],
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./react-native-web": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/react-native-web.native.js",
      "browser": "./dist/esm/react-native-web.mjs",
      "module": "./dist/esm/react-native-web.mjs",
      "import": "./dist/esm/react-native-web.mjs",
      "require": "./dist/cjs/react-native-web.cjs",
      "default": "./dist/esm/react-native-web.mjs"
    },
    "./web": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./native": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/native.cjs",
      "require": "./dist/native.cjs",
      "default": "./dist/native.cjs"
    },
    "./native-test": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/test.native.js",
      "require": "./dist/test.cjs",
      "default": "./dist/test.cjs"
    },
    "./linear-gradient": {
      "types": "./types/linear-gradient.d.ts",
      "react-native": "./dist/esm/linear-gradient.native.js",
      "browser": "./dist/esm/linear-gradient.mjs",
      "module": "./dist/esm/linear-gradient.mjs",
      "import": "./dist/esm/linear-gradient.mjs",
      "require": "./dist/cjs/linear-gradient.cjs",
      "default": "./dist/esm/linear-gradient.mjs"
    }
  },
  "scripts": {
    "build": "tamagui-build",
    "afterBuild": "node bundle-native.mjs",
    "watch": "tamagui-build --watch",
    "clean": "tamagui-build clean",
    "clean:build": "tamagui-build clean:build",
    "check": "bun run check-circular-deps",
    "check-circular-deps": "npx madge --circular ./src/index.ts"
  },
  "dependencies": {
    "@tamagui/accordion": "2.0.0-rc.36",
    "@tamagui/adapt": "2.0.0-rc.36",
    "@tamagui/alert-dialog": "2.0.0-rc.36",
    "@tamagui/animate": "2.0.0-rc.36",
    "@tamagui/animate-presence": "2.0.0-rc.36",
    "@tamagui/avatar": "2.0.0-rc.36",
    "@tamagui/button": "2.0.0-rc.36",
    "@tamagui/card": "2.0.0-rc.36",
    "@tamagui/checkbox": "2.0.0-rc.36",
    "@tamagui/collapsible": "2.0.0-rc.36",
    "@tamagui/compose-refs": "2.0.0-rc.36",
    "@tamagui/constants": "2.0.0-rc.36",
    "@tamagui/context-menu": "2.0.0-rc.36",
    "@tamagui/core": "2.0.0-rc.36",
    "@tamagui/create-context": "2.0.0-rc.36",
    "@tamagui/create-menu": "2.0.0-rc.36",
    "@tamagui/dialog": "2.0.0-rc.36",
    "@tamagui/element": "2.0.0-rc.36",
    "@tamagui/elements": "2.0.0-rc.36",
    "@tamagui/fake-react-native": "2.0.0-rc.36",
    "@tamagui/focusable": "2.0.0-rc.36",
    "@tamagui/form": "2.0.0-rc.36",
    "@tamagui/get-button-sized": "2.0.0-rc.36",
    "@tamagui/get-font-sized": "2.0.0-rc.36",
    "@tamagui/get-token": "2.0.0-rc.36",
    "@tamagui/group": "2.0.0-rc.36",
    "@tamagui/helpers-tamagui": "2.0.0-rc.36",
    "@tamagui/image": "2.0.0-rc.36",
    "@tamagui/input": "2.0.0-rc.36",
    "@tamagui/label": "2.0.0-rc.36",
    "@tamagui/linear-gradient": "2.0.0-rc.36",
    "@tamagui/list-item": "2.0.0-rc.36",
    "@tamagui/menu": "2.0.0-rc.36",
    "@tamagui/polyfill-dev": "2.0.0-rc.36",
    "@tamagui/popover": "2.0.0-rc.36",
    "@tamagui/popper": "2.0.0-rc.36",
    "@tamagui/portal": "2.0.0-rc.36",
    "@tamagui/progress": "2.0.0-rc.36",
    "@tamagui/radio-group": "2.0.0-rc.36",
    "@tamagui/react-native-media-driver": "2.0.0-rc.36",
    "@tamagui/scroll-view": "2.0.0-rc.36",
    "@tamagui/select": "2.0.0-rc.36",
    "@tamagui/separator": "2.0.0-rc.36",
    "@tamagui/shapes": "2.0.0-rc.36",
    "@tamagui/sheet": "2.0.0-rc.36",
    "@tamagui/slider": "2.0.0-rc.36",
    "@tamagui/spacer": "2.0.0-rc.36",
    "@tamagui/spinner": "2.0.0-rc.36",
    "@tamagui/stacks": "2.0.0-rc.36",
    "@tamagui/switch": "2.0.0-rc.36",
    "@tamagui/tabs": "2.0.0-rc.36",
    "@tamagui/text": "2.0.0-rc.36",
    "@tamagui/theme": "2.0.0-rc.36",
    "@tamagui/toast": "2.0.0-rc.36",
    "@tamagui/toggle-group": "2.0.0-rc.36",
    "@tamagui/tooltip": "2.0.0-rc.36",
    "@tamagui/use-controllable-state": "2.0.0-rc.36",
    "@tamagui/use-debounce": "2.0.0-rc.36",
    "@tamagui/use-force-update": "2.0.0-rc.36",
    "@tamagui/use-window-dimensions": "2.0.0-rc.36",
    "@tamagui/v2-toast": "2.0.0-rc.36",
    "@tamagui/visually-hidden": "2.0.0-rc.36",
    "@tamagui/font-size": "2.0.0-rc.36",
    "@tamagui/z-index-stack": "2.0.0-rc.36"
  },
  "devDependencies": {
    "@tamagui/build": "2.0.0-rc.36",
    "react": ">=19",
    "react-native": "0.83.2",
    "react-native-web": "^0.21.0"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": "*"
  },
  "alsoPublishAs_disabled": [
    "@tamagui/ui"
  ],
  "module:jsx": "dist/jsx",
  "removeSideEffects": true
}
