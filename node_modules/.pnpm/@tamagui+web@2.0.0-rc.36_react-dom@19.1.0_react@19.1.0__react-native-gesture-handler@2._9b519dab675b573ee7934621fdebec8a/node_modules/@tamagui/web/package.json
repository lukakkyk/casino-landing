{
  "name": "@tamagui/web",
  "version": "2.0.0-rc.36",
  "license": "MIT",
  "author": {
    "name": "Nate Wienert"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tamagui/tamagui.git",
    "directory": "packages/web"
  },
  "source": "src/index.ts",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./reset.css": "./reset.css",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./inject-styles": {
      "types": "./types/inject-styles.d.ts",
      "react-native": "./dist/esm/inject-styles.mjs",
      "browser": "./dist/esm/inject-styles.mjs",
      "module": "./dist/esm/inject-styles.mjs",
      "import": "./dist/esm/inject-styles.mjs",
      "require": "./dist/cjs/inject-styles.cjs",
      "default": "./dist/cjs/inject-styles.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tamagui-build",
    "watch": "tamagui-build --watch",
    "clean": "tamagui-build clean",
    "clean:build": "tamagui-build clean:build",
    "test:web": "vitest --typecheck --run"
  },
  "dependencies": {
    "@tamagui/compose-refs": "2.0.0-rc.36",
    "@tamagui/constants": "2.0.0-rc.36",
    "@tamagui/helpers": "2.0.0-rc.36",
    "@tamagui/is-equal-shallow": "2.0.0-rc.36",
    "@tamagui/native": "2.0.0-rc.36",
    "@tamagui/normalize-css-color": "2.0.0-rc.36",
    "@tamagui/timer": "2.0.0-rc.36",
    "@tamagui/types": "2.0.0-rc.36",
    "@tamagui/use-did-finish-ssr": "2.0.0-rc.36",
    "@tamagui/use-event": "2.0.0-rc.36",
    "@tamagui/use-force-update": "2.0.0-rc.36"
  },
  "devDependencies": {
    "@tamagui/build": "2.0.0-rc.36",
    "@testing-library/react": "^16.1.0",
    "csstype": "^3.0.10",
    "react": ">=19",
    "react-dom": "*",
    "react-native": "0.83.2",
    "typescript": "~5.9.2",
    "vitest": "4.0.4"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": "*",
    "react-native": "*"
  }
}
