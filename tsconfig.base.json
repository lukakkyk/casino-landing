{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "jsx": "react-jsx",
        "allowJs": false,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@casino/config": ["packages/config/src/index.ts"],
            "@casino/shared-api": ["packages/shared-api/src/index.ts"],
            "@casino/shared-stores": ["packages/shared-stores/src/index.ts"],
            "@casino/shared-ui": ["packages/shared-ui/src/index.ts"]
        }
    }
}