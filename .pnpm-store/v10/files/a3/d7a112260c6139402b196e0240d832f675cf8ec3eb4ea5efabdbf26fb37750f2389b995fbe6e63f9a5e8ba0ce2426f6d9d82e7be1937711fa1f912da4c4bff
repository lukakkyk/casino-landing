{
  "name": "@tamagui/sheet",
  "version": "2.0.0-rc.36",
  "license": "MIT",
  "source": "src/index.ts",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "typesVersions": {
    "*": {
      "setup-gesture-handler": [
        "./types/setupGestureHandler.d.ts"
      ]
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./controller": {
      "types": "./types/controller.d.ts",
      "react-native": "./dist/esm/controller.native.js",
      "browser": "./dist/esm/controller.mjs",
      "module": "./dist/esm/controller.mjs",
      "import": "./dist/esm/controller.mjs",
      "require": "./dist/cjs/controller.cjs",
      "default": "./dist/cjs/controller.native.js"
    },
    "./setup-gesture-handler": {
      "types": "./types/setupGestureHandler.d.ts",
      "react-native": "./dist/esm/setupGestureHandler.native.js",
      "browser": "./dist/esm/setupGestureHandler.mjs",
      "module": "./dist/esm/setupGestureHandler.mjs",
      "import": "./dist/esm/setupGestureHandler.mjs",
      "require": "./dist/cjs/setupGestureHandler.cjs",
      "default": "./dist/esm/setupGestureHandler.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tamagui-build",
    "watch": "tamagui-build --watch",
    "clean": "tamagui-build clean"
  },
  "dependencies": {
    "@tamagui/adapt": "2.0.0-rc.36",
    "@tamagui/animate-presence": "2.0.0-rc.36",
    "@tamagui/animations-react-native": "2.0.0-rc.36",
    "@tamagui/compose-refs": "2.0.0-rc.36",
    "@tamagui/constants": "2.0.0-rc.36",
    "@tamagui/core": "2.0.0-rc.36",
    "@tamagui/create-context": "2.0.0-rc.36",
    "@tamagui/helpers": "2.0.0-rc.36",
    "@tamagui/native": "2.0.0-rc.36",
    "@tamagui/portal": "2.0.0-rc.36",
    "@tamagui/remove-scroll": "2.0.0-rc.36",
    "@tamagui/scroll-view": "2.0.0-rc.36",
    "@tamagui/stacks": "2.0.0-rc.36",
    "@tamagui/use-constant": "2.0.0-rc.36",
    "@tamagui/use-controllable-state": "2.0.0-rc.36",
    "@tamagui/use-did-finish-ssr": "2.0.0-rc.36",
    "@tamagui/use-keyboard-visible": "2.0.0-rc.36",
    "@tamagui/z-index-stack": "2.0.0-rc.36"
  },
  "devDependencies": {
    "@tamagui/build": "2.0.0-rc.36",
    "react": ">=19",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": "*",
    "react-native-gesture-handler": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-gesture-handler": {
      "optional": true
    }
  },
  "module:jsx": "dist/jsx",
  "removeSideEffects": true
}
