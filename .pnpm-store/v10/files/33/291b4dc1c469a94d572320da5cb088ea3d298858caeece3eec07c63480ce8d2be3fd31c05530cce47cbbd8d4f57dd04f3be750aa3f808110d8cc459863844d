{
  "name": "@tamagui/theme-builder",
  "version": "2.0.0-rc.36",
  "source": "src/index.ts",
  "files": [
    "src",
    "types",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tamagui-build",
    "watch": "tamagui-build --watch",
    "clean": "tamagui-build clean",
    "clean:build": "tamagui-build clean:build",
    "test": "vitest --run",
    "test:web": "bun run test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tamagui/create-theme": "2.0.0-rc.36",
    "@tamagui/web": "2.0.0-rc.36",
    "color2k": "^2.0.2"
  },
  "devDependencies": {
    "@tamagui/build": "2.0.0-rc.36",
    "vitest": "4.0.4"
  }
}
