{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "lib": ["DOM", "ESNext"],
    "moduleResolution": "bundler",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@casino/config": [
        "../../packages/config/src/index.ts"
      ],
      "@casino/shared-api": [
        "../../packages/shared-api/src/index.ts"
      ],
      "@casino/shared-stores": [
        "../../packages/shared-stores/src/index.ts"
      ],
      "@casino/shared-ui": [
        "../../packages/shared-ui/src/index.ts"
      ],
      "expo-router": [
        "./node_modules/expo-router/build/index.d.ts"
      ],
      "expo-router/*": [
        "./node_modules/expo-router/build/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "../../packages/shared-ui/src/declarations.d.ts"
  ]
}
